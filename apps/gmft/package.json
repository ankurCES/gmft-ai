{
  "name": "gmft",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "GMFT-AI terminal UI",
  "bin": {
    "gmft": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x ./dist/cli.js",
    "start": "node ./dist/cli.js",
    "dev": "tsx ./src/cli.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo 'lint pending'",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@gmft/core": "workspace:*",
    "@gmft/testkit": "workspace:*",
    "@gmft/tools": "workspace:*",
    "zod": "^3.25.76",
    "chalk": "^5.3.0",
    "ink": "^5.0.1",
    "ink-gradient": "^3.0.0",
    "ink-spinner": "^5.0.0",
    "ink-syntax-highlight": "^2.0.0",
    "ink-table": "^3.0.0",
    "ink-text-input": "^6.0.0",
    "meow": "^13.2.0",
    "pastel": "^3.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "ink-testing-library": "^4.0.0",
    "jsdom": "^25.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
