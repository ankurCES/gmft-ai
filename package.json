{
  "name": "gmft-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Terminal-first agentic runtime for authorized penetration testing",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' --filter './apps/*' build",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r --parallel test:watch",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml,toml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml,toml}\"",
    "check-tools": "bash scripts/check-tools.sh"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  }
}
